# Cast — environment configuration
# Copy to .env.local: cp .env.example .env.local
# (.env.local is git-ignored by Next.js and is the recommended file for
# local secrets. .env also works if you prefer it.)

# ── Required ──────────────────────────────────────────────────────────────────
# OpenAI API key. Read by the OpenAI SDK.
OPENAI_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# Storage backend: local (default) | azure.
# CAST_STORAGE=local
# Azure connection string — required when CAST_STORAGE=azure.
# AZURE_STORAGE_CONNECTION_STRING=

# ── Vector DB (optional — features degrade gracefully) ────────────────────────
# QDRANT_URL=
# QDRANT_API_KEY=

# ── GenAI ─────────────────────────────────────────────────────────────────────
# GenAI mode: default | cheap. Default: default.
# default = dall-e-3, three native sizes, one call per ratio.
# cheap   = gpt-image-1, one call per missing product + Sharp center-crop.
# CAST_GENAI_MODE=default

# Client-side GenAI mode badge. Mirrors CAST_GENAI_MODE at build time so S1
# can render a read-only mode pill without a runtime API call.
# NEXT_PUBLIC_CAST_GENAI_MODE=default

# ── Ads provider (future) ────────────────────────────────────────────────────
# manual (default) | meta (when MetaAdsProvider is wired).
# CAST_ADS_PROVIDER=manual
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# ── Fatigue ───────────────────────────────────────────────────────────────────
# Threshold score above which a creative is flagged as fatigued.
# CAST_FATIGUE_THRESHOLD=45

# ── Dropbox export (optional) ────────────────────────────────────────────────
# Public client ID (not a secret). Enables the "Export to Dropbox" button.
# See README § "V2 Upgrade Paths → Cloud Export — Dropbox" for full setup.
# NEXT_PUBLIC_DROPBOX_APP_KEY=

# ── API split (future — when Fastify repo exists) ────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:4000
